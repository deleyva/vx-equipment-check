{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "cp index.html styles.css script.js vitalinux-logo.png dist/",
    "beforeDevCommand": "cp index.html styles.css script.js vitalinux-logo.png dist/",
    "devPath": "../dist",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "vx-dga-pc-check-form",
    "version": "1.0.10"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "save": true
      },
      "fs": {
        "all": false,
        "writeFile": true,
        "readFile": true,
        "createDir": true,
        "scope": ["$DESKTOP", "$DOCUMENT", "$DOWNLOAD", "$HOME"]
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": ["libwebkit2gtk-4.0-37", "libgtk-3-0"],
        "desktopTemplate": "desktop-template.desktop",
        "files": {
          "autostart/vx-dga-pc-check-form.desktop": "/etc/xdg/autostart/"
        }
      },
      "externalBin": [],
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
      "identifier": "com.vitalinux.equipment-check",
      "longDescription": "Aplicación de verificación de equipos de escritorio para VITALINUX",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Abre el formulario de comprobación de PC Vitalinux",
      "targets": ["deb"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": true,
        "decorations": false,
        "height": 900,
        "resizable": true,
        "title": "VITALINUX - Verificación de Equipos",
        "width": 1200,
        "minHeight": 600,
        "minWidth": 800,
        "center": true
      }
    ]
  }
}
